@media (max-width: 480px) {
  .search-header {
    padding: var(--space-8) 0;
  }
  
  .search-input-group {
    flex-direction: column;
    border-radius: var(--radius-md);
  }
  
  .search-input {
    padding: var(--space-4) var(--space-4) var(--space-4) var(--space-12);
  }
  
  .search-button {

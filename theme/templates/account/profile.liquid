{% layout 'layout/theme' %}

<section class="account-page">
  <div class="container">
    <div class="account-header">
      <h1 class="account-title">My Profile</h1>
      <p class="account-subtitle">Manage your account information and preferences</p>
    </div>

    <div class="account-layout">
      <!-- Account Sidebar -->
      <aside class="account-sidebar">
        {% render 'snippets/account-sidebar' %}
      </aside>

      <!-- Profile Content -->
      <div class="account-content">
        {% hook 'account_profile_before' %}
        
       

        <div class="profile-form-container">
          <div class="form-section-header">
            <h3 class="form-section-title">Personal Information</h3>
            <p class="form-section-description">Update your personal details and contact information</p>
          </div>

          <form id="profile-form" class="profile-form">
            <div class="form-grid">
              <div class="form-group">
                <label for="profile-first-name" class="form-label">
                  <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                    <circle cx="12" cy="7" r="4"></circle>
                  </svg>
                  Full Name
                </label>
                <input 
                  type="text" 
                  id="profile-first-name" 
                  name="firstName" 
                  class="form-input" 
                  value="{{ customer.fullName }}"
                  placeholder="Enter your full name"
                  required
                >
              </div>

              <div class="form-group">
                <label for="profile-email" class="form-label">
                  <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                  Email Address
                </label>
                <div class="input-with-badge">
                  <input 
                    type="email" 
                    id="profile-email" 
                    name="email" 
                    class="form-input" 
                    value="{{ customer.email }}" 
                    readonly
                  >
                  <span class="input-badge">Verified</span>
                </div>
                <p class="form-help-text">Contact support to change your email address</p>
              </div>

              <div class="form-group">
                <label for="profile-phone" class="form-label">
                  <svg class="label-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                  Phone Number
                </label>
                <input 
                  type="tel" 
                  id="profile-phone" 
                  name="phone" 
                  class="form-input" 
                  value="{{ customer.phone }}"
                  placeholder="+1 (555) 000-0000"
                >
              </div>
            </div>

            <div class="form-actions">
              <button type="submit" class="btn btn-primary" id="save-profile-btn">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path>
                  <polyline points="17 21 17 13 7 13 7 21"></polyline>
                  <polyline points="7 3 7 8 15 8"></polyline>
                </svg>
                <span class="btn-text">Save Changes</span>
                <span class="btn-loading" style="display: none;">
                  <span class="btn-spinner"></span>
                  <span>Saving...</span>
                </span>
              </button>
              <button type="reset" class="btn btn-outline">Cancel</button>
            </div>
          </form>
        </div>

        <!-- Danger Zone -->
        <div class="danger-zone">
          <div class="danger-zone-header">
            <svg class="danger-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
              <line x1="12" y1="9" x2="12" y2="13"></line>
              <line x1="12" y1="17" x2="12.01" y2="17"></line>
            </svg>
            <div>
              <h3 class="danger-zone-title">Danger Zone</h3>
              <p class="danger-zone-text">
                Permanently delete your account and all associated data. This action cannot be undone.
              </p>
            </div>
          </div>
          <button type="button" class="btn btn-danger" id="request-account-deletion-btn">
            <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
            Request Account Deletion
          </button>
        </div>

        {% hook 'account_profile_after' %}
      </div>
    </div>
  </div>
</section>

<!-- Account Deletion Reason Modal -->
<div class="deletion-modal-overlay" id="deletion-modal" style="display: none;">
  <div class="deletion-modal">
    <div class="deletion-modal-header">
      <h3 class="deletion-modal-title">Delete Account</h3>
      <button type="button" class="deletion-modal-close" id="deletion-modal-close" aria-label="Close">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <div class="deletion-modal-body">
      <p class="deletion-modal-warning">
        <svg class="deletion-modal-warning-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path>
          <line x1="12" y1="9" x2="12" y2="13"></line>
          <line x1="12" y1="17" x2="12.01" y2="17"></line>
        </svg>
        This action is permanent and cannot be undone. All your data will be deleted.
      </p>
      <label class="deletion-modal-label" for="deletion-reason">
        Please tell us why you want to delete your account <span class="required">*</span>
      </label>
      <textarea 
        id="deletion-reason" 
        class="deletion-modal-textarea" 
        placeholder="Enter your reason for account deletion..."
        rows="4"
        required
      ></textarea>
      <p class="deletion-modal-error" id="deletion-reason-error" style="display: none;">
        Please provide a reason for account deletion.
      </p>
    </div>
    <div class="deletion-modal-footer">
      <button type="button" class="btn btn-secondary" id="deletion-modal-cancel">Cancel</button>
      <button type="button" class="btn btn-danger" id="deletion-modal-confirm">
        <span class="btn-text">Delete My Account</span>
        <span class="btn-loading" style="display: none;">
          <svg class="spinner" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="32" stroke-linecap="round"></circle>
          </svg>
          Deleting...
        </span>
      </button>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {

  /* ===============================
     Button Loading Utility
  =============================== */
  function setButtonLoading(button, loading) {
    if (!button) return;

    const btnText = button.querySelector('.btn-text');
    const btnLoading = button.querySelector('.btn-loading');

    button.disabled = loading;

    if (btnText) btnText.style.display = loading ? 'none' : 'inline';
    if (btnLoading) btnLoading.style.display = loading ? 'inline-flex' : 'none';
  }

  /* ===============================
     Phone Input Initialization
  =============================== */
  let iti = null;
  const phoneInput = document.getElementById('profile-phone');

  if (phoneInput && typeof intlTelInput !== 'undefined') {
    iti = intlTelInput(phoneInput, {
      utilsScript: 'https://cdn.jsdelivr.net/npm/intl-tel-input@23.0.0/build/js/utils.js',
      initialCountry: 'auto',
      geoIpLookup: function (callback) {
        fetch('https://ipapi.co/json/')
          .then(res => res.json())
          .then(data => callback(data.country_code ? data.country_code.toLowerCase() : 'us'))
          .catch(() => callback('us'));
      },
      separateDialCode: true,
      nationalMode: false
    });
  }

  /* ===============================
     Profile Form Submission
  =============================== */
  const profileForm = document.getElementById('profile-form');

  if (profileForm) {
    profileForm.addEventListener('submit', async function (e) {
      e.preventDefault();

      const submitBtn = document.getElementById('save-profile-btn');
      setButtonLoading(submitBtn, true);

      const formData = new FormData(this);

      let phoneNumber = formData.get('phone');
      if (iti) {
        const fullPhone = iti.getNumber();
        if (fullPhone) {
          phoneNumber = fullPhone.replace(/^\+/, '');
        }
      }

      const data = {
        fullName: formData.get('firstName'),
        email: formData.get('email'),
        phoneNumber: phoneNumber
      };

      try {
        const response = await fetch('/webstoreapi/customer/profile', {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify(data)
        });

        if (response.ok) {
          window.location.reload();
        } else {
          const error = await response.json();
          alert(error.message || 'Error updating profile');
          setButtonLoading(submitBtn, false);
        }
      } catch (error) {
        console.error('Profile update error:', error);
        alert('Error updating profile. Please try again.');
        setButtonLoading(submitBtn, false);
      }
    });
  }

  /* ===============================
     Account Deletion Request
  =============================== */
  const deleteBtn = document.getElementById('request-account-deletion-btn');
  const deletionModal = document.getElementById('deletion-modal');
  const deletionModalClose = document.getElementById('deletion-modal-close');
  const deletionModalCancel = document.getElementById('deletion-modal-cancel');
  const deletionModalConfirm = document.getElementById('deletion-modal-confirm');
  const deletionReasonTextarea = document.getElementById('deletion-reason');
  const deletionReasonError = document.getElementById('deletion-reason-error');

  // Show modal
  function showDeletionModal() {
    if (deletionModal) {
      deletionModal.style.display = 'flex';
      deletionReasonTextarea.value = '';
      deletionReasonError.style.display = 'none';
      deletionReasonTextarea.focus();
      document.body.style.overflow = 'hidden';
    }
  }

  // Hide modal
  function hideDeletionModal() {
    if (deletionModal) {
      deletionModal.style.display = 'none';
      document.body.style.overflow = '';
    }
  }

  // Set confirm button loading state
  function setConfirmButtonLoading(loading) {
    if (!deletionModalConfirm) return;
    const btnText = deletionModalConfirm.querySelector('.btn-text');
    const btnLoading = deletionModalConfirm.querySelector('.btn-loading');
    
    if (loading) {
      deletionModalConfirm.disabled = true;
      if (btnText) btnText.style.display = 'none';
      if (btnLoading) btnLoading.style.display = 'inline-flex';
    } else {
      deletionModalConfirm.disabled = false;
      if (btnText) btnText.style.display = '';
      if (btnLoading) btnLoading.style.display = 'none';
    }
  }

  // Submit deletion request
  async function submitDeletionRequest() {
    const reason = deletionReasonTextarea.value.trim();
    
    // Validate reason is provided
    if (!reason) {
      deletionReasonError.style.display = 'block';
      deletionReasonTextarea.focus();
      return;
    }
    
    deletionReasonError.style.display = 'none';
    setConfirmButtonLoading(true);

    try {
      const response = await fetch('/webstoreapi/customer/account/delete-request', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify({ reason: reason })
      });

      const responseData = await response.json();
      
      if (response.ok) {
        // Show success message from the API
        const successMessage = responseData.data?.message || responseData.message || 'Account deletion request submitted successfully.';
        alert(successMessage);
        
        // Logout the user after showing the message
        window.location.href = '/webstoreapi/customer/logout';
      } else {
        alert(responseData.error || responseData.message || 'Error requesting account deletion');
        setConfirmButtonLoading(false);
      }
    } catch (error) {
      console.error('Account deletion error:', error);
      alert('Error requesting account deletion. Please try again.');
      setConfirmButtonLoading(false);
    }
  }

  // Event listeners
  if (deleteBtn) {
    deleteBtn.addEventListener('click', showDeletionModal);
  }

  if (deletionModalClose) {
    deletionModalClose.addEventListener('click', hideDeletionModal);
  }

  if (deletionModalCancel) {
    deletionModalCancel.addEventListener('click', hideDeletionModal);
  }

  if (deletionModalConfirm) {
    deletionModalConfirm.addEventListener('click', submitDeletionRequest);
  }

  // Close modal on overlay click
  if (deletionModal) {
    deletionModal.addEventListener('click', function(e) {
      if (e.target === deletionModal) {
        hideDeletionModal();
      }
    });
  }

  // Close modal on Escape key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && deletionModal && deletionModal.style.display === 'flex') {
      hideDeletionModal();
    }
  });

  // Hide error when user starts typing
  if (deletionReasonTextarea) {
    deletionReasonTextarea.addEventListener('input', function() {
      if (this.value.trim()) {
        deletionReasonError.style.display = 'none';
      }
    });
  }

});
</script>


<style>
:root {
  --shadow-md: var(--shadow-md);
  --shadow-lg: var(--shadow-lg);
  --shadow-xl: var(--shadow-xl);
  --radius-sm: var(--radius-md);
  --radius-md: var(--radius-lg);
  --radius-lg: var(--radius-xl);
  --radius-xl: var(--radius-2xl);
  --transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  --color-white: #ffffff;
}

* {
  box-sizing: border-box;
}

/* ===============================
   Account Deletion Modal Styles
=============================== */
.deletion-modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(4px);
  z-index: 9999;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 1rem;
}

.deletion-modal {
  background: var(--color-white, #fff);
  border-radius: var(--radius-lg, 12px);
  box-shadow: var(--shadow-xl, 0 25px 50px -12px rgba(0, 0, 0, 0.25));
  width: 100%;
  max-width: 480px;
  max-height: 90vh;
  overflow: hidden;
  animation: modalSlideIn 0.2s ease-out;
}

@keyframes modalSlideIn {
  from {
    opacity: 0;
    transform: scale(0.95) translateY(-10px);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.deletion-modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 1.25rem 1.5rem;
  border-bottom: 1px solid var(--color-border, #e5e7eb);
  background: linear-gradient(to right, #fef2f2, #fff);
}

.deletion-modal-title {
  margin: 0;
  font-size: 1.25rem;
  font-weight: 600;
  color: #dc2626;
}

.deletion-modal-close {
  background: transparent;
  border: none;
  cursor: pointer;
  padding: 0.5rem;
  color: var(--color-text-muted, #6b7280);
  border-radius: 0.375rem;
  transition: background 0.2s, color 0.2s;
}

.deletion-modal-close:hover {
  background: var(--color-surface-hover, #f3f4f6);
  color: var(--color-text, #111827);
}

.deletion-modal-close svg {
  width: 20px;
  height: 20px;
}

.deletion-modal-body {
  padding: 1.5rem;
}

.deletion-modal-warning {
  display: flex;
  align-items: flex-start;
  gap: 0.75rem;
  padding: 1rem;
  background: #fef2f2;
  border: 1px solid #fecaca;
  border-radius: var(--radius-md, 8px);
  color: #991b1b;
  font-size: 0.875rem;
  line-height: 1.5;
  margin: 0 0 1.25rem 0;
}

.deletion-modal-warning-icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  stroke: #dc2626;
}

.deletion-modal-label {
  display: block;
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--color-text, #374151);
  margin-bottom: 0.5rem;
}

.deletion-modal-label .required {
  color: #dc2626;
}

.deletion-modal-textarea {
  width: 100%;
  padding: 0.75rem 1rem;
  border: 1px solid var(--color-border, #d1d5db);
  border-radius: var(--radius-md, 8px);
  font-size: 0.9375rem;
  font-family: inherit;
  resize: vertical;
  min-height: 100px;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.deletion-modal-textarea:focus {
  outline: none;
  border-color: #dc2626;
  box-shadow: 0 0 0 3px rgba(220, 38, 38, 0.1);
}

.deletion-modal-textarea::placeholder {
  color: var(--color-text-muted, #9ca3af);
}

.deletion-modal-error {
  margin: 0.5rem 0 0 0;
  font-size: 0.8125rem;
  color: #dc2626;
}

.deletion-modal-footer {
  display: flex;
  gap: 0.75rem;
  justify-content: flex-end;
  padding: 1rem 1.5rem;
  border-top: 1px solid var(--color-border, #e5e7eb);
  background: var(--color-surface, #f9fafb);
}

.deletion-modal-footer .btn {
  padding: 0.625rem 1.25rem;
  font-size: 0.875rem;
  font-weight: 500;
  border-radius: var(--radius-md, 8px);
  cursor: pointer;
  transition: all 0.2s;
}

.deletion-modal-footer .btn-secondary {
  background: var(--color-white, #fff);
  border: 1px solid var(--color-border, #d1d5db);
  color: var(--color-text, #374151);
}

.deletion-modal-footer .btn-secondary:hover {
  background: var(--color-surface-hover, #f3f4f6);
}

.deletion-modal-footer .btn-danger {
  background: #dc2626;
  border: 1px solid #dc2626;
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
}

.deletion-modal-footer .btn-danger:hover:not(:disabled) {
  background: #b91c1c;
  border-color: #b91c1c;
}

.deletion-modal-footer .btn-danger:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.deletion-modal-footer .btn-loading {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
}

.deletion-modal-footer .spinner {
  width: 16px;
  height: 16px;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

@media (max-width: 480px) {
  .deletion-modal-footer {
    flex-direction: column-reverse;
  }
  
  .deletion-modal-footer .btn {
    width: 100%;
    justify-content: center;
  }
}

.account-page {
  padding: 2rem 1rem;
  background: linear-gradient(to bottom, var(--color-background) 0%, var(--color-surface) 100%);
  min-height: 100vh;
}

.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 1rem;
}

.account-header {
  text-align: center;
  margin-bottom: 3rem;
}

.account-title {
  font-size: clamp(2rem, 5vw, 2.5rem);
  font-weight: 700;
  color: var(--color-text);
  margin: 0 0 0.5rem 0;
  letter-spacing: -0.025em;
}

.account-subtitle {
  font-size: clamp(0.9375rem, 2vw, 1.125rem);
  color: var(--color-text-muted);
  margin: 0;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.account-layout {
  display: grid;
  grid-template-columns: 280px 1fr;
  gap: 2rem;
  align-items: start;
}

.account-sidebar {
  position: sticky;
  top: 2rem;
  background: var(--color-background);
  border-radius: var(--radius-xl);
  padding: 1.5rem;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--color-border);
  transition: var(--transition);
}

.account-sidebar:hover {
  box-shadow: var(--shadow-lg);
}

.account-content {
  background: var(--color-background);
  border-radius: var(--radius-xl);
  padding: 0;
  box-shadow: var(--shadow-md);
  border: 1px solid var(--color-border);
  overflow: hidden;
}

/* Profile Header */
.profile-header {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  padding: 2rem;
  background: linear-gradient(135deg, var(--color-primary-light) 0%, var(--color-surface) 100%);
  border-bottom: 1px solid var(--color-border);
}

.profile-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-hover) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-lg);
  flex-shrink: 0;
}

.avatar-icon {
  width: 45px;
  height: 45px;
  color: var(--color-white);
}

.profile-header-text {
  flex: 1;
  min-width: 0;
}

.profile-name {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-text);
  margin: 0 0 0.25rem 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-email {
  font-size: 1.4rem;
  color: var(--color-text-muted);
  margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Form Container */
.profile-form-container {
  padding: 2rem;
}

.form-section-header {
  margin-bottom: 2rem;
}

.form-section-title {
  font-size: 1.4em;
  font-weight: 600;
  color: var(--color-text);
  margin: 0 0 0.5rem 0;
}

.form-section-description {
  font-size:1.4rem;
  color: var(--color-text-muted);
  margin: 0;
}

/* Form Styles */
.profile-form {
  width: 100%;
}

.form-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.form-label {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1.4rem;
  font-weight: 600;
  color: var(--color-text);
  letter-spacing: 0.01em;
}

.label-icon {

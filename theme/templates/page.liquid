{% layout 'layout/theme' %}

{% hook 'page_before' %}
<div class="page-content">
  <div class="page-header">
    <h1 class="page-title">{{ page.title }}</h1>
    {% if page.subtitle %}
      <p class="page-subtitle">{{ page.subtitle }}</p>
    {% endif %}
  </div>
  
  <div class="page-body">
    {% hook 'page_content_before' %}
    <div class="page-content-wrapper">
      {% if page.content %}
        <div class="page-text">
          {{ page.content }}
        </div>
      {% else %}
        <div class="page-text">
          <p>Welcome to {{ shop.name }}! This is a sample page content.</p>
          <p>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris nisi ut aliquip ex ea commodo consequat.</p>
          
          <h2>Our Mission</h2>
          <p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum dolore eu fugiat nulla pariatur. Excepteur sint occaecat cupidatat non proident, sunt in culpa qui officia deserunt mollit anim id est laborum.</p>
          
          <h2>Contact Information</h2>
          <p>If you have any questions or need assistance, please don't hesitate to contact us:</p>
          <ul>
            <li>Email: support@{{ shop.domain }}</li>
            <li>Phone: (555) 123-4567</li>
            <li>Address: 123 Main Street, City, State 12345</li>
          </ul>
        </div>
      {% endif %}
    </div>
    
    <!-- Page sidebar (optional) -->
    <div class="page-sidebar">
      <div class="sidebar-widget">
        <h3>Quick Links</h3>
        <ul class="sidebar-links">
          <li><a href="/">Home</a></li>
          <li><a href="/products">Products</a></li>
          <li><a href="/">Collections</a></li>
          <li><a href="/pages/about">About Us</a></li>
          <li><a href="/pages/contact">Contact</a></li>
        </ul>
      </div>
      
      <div class="sidebar-widget">
        <h3>Customer Service</h3>
        <ul class="sidebar-links">
          <li><a href="/pages/shipping">Shipping Info</a></li>
          <li><a href="/pages/returns">Returns & Exchanges</a></li>
          <li><a href="/pages/privacy">Privacy Policy</a></li>
          <li><a href="/pages/terms">Terms of Service</a></li>
        </ul>
      </div>
      
      <div class="sidebar-widget">
        <h3>Newsletter</h3>
        <p>Stay updated with our latest products and offers.</p>
        <form class="newsletter-form" action="/webstoreapi/newsletter/subscribe" method="post">
          <input type="email" name="email" placeholder="Enter your email" required>
          <button type="submit" class="btn btn-primary">Subscribe</button>
        </form>
      </div>
    </div>
    {% hook 'page_content_after' %}
  </div>
</div>
{% hook 'page_after' %}

<style>
  /* CSS Variables from Theme Settings */
  :root {
    --color-primary: {{ settings.color_primary | default: '#000000' }};
    --color-primary-hover: {{ settings.color_primary_dark | default: '#333333' }};
    --color-primary-light: {{ settings.color_primary_light | default: '#666666' }};
    --color-success: {{ settings.color_success | default: '#22c55e' }};
    --color-danger: {{ settings.color_error | default: '#ef4444' }};
    --color-text: {{ settings.color_text | default: '#000000' }};
    --color-text-light: {{ settings.color_text_muted | default: '#666666' }};
    --color-background: {{ settings.color_background | default: '#ffffff' }};
    --color-card-bg: {{ settings.color_surface | default: '#f5f5f5' }};
    --color-border: {{ settings.color_border | default: '#cccccc' }};
  }

  /* CRITICAL: Prevent horizontal scrolling at all levels */
  * {
    box-sizing: border-box;
  }

  html {
    overflow-x: hidden;
    width: 100%;
  }

  body {
    overflow-x: hidden;
    width: 100%;
    max-width: 100vw;
  }

  /* Main Container - Strict width control */
  .page-content {
    width: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 3vw, 2rem);
    overflow-x: hidden;
    box-sizing: border-box;
  }

  /* Page Header */
  .page-header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
    padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 3rem);
    background: linear-gradient(135deg, 
      color-mix(in srgb, var(--color-primary) 5%, var(--color-background)) 0%, 
      color-mix(in srgb, var(--color-primary) 10%, var(--color-background)) 100%);
    border-radius: clamp(0.75rem, 1.5vw, 1.25rem);
    border: 1px solid color-mix(in srgb, var(--color-border) 50%, transparent);
    overflow: hidden;
  }

  .page-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 clamp(0.75rem, 2vw, 1.25rem) 0;
    color: var(--color-text);
    font-weight: 700;
    line-height: 1.2;
  }

  .page-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    color: var(--color-text-light);
    max-width: 46rem;
    margin: 0 auto;
    line-height: 1.6;
  }

  /* Page Body Grid - CRITICAL: Use minmax(0, ...) to prevent overflow */
  .page-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    width: 100%;
    max-width: 100%;
    overflow-x: hidden;
    box-sizing: border-box;
  }

  @media (min-width: 1024px) {
    .page-body {
      grid-template-columns: minmax(0, 2.5fr) minmax(0, 1fr);
    }
  }

  /* Content Wrapper - ABSOLUTE overflow prevention */
  .page-content-wrapper {
    background: var(--color-background);
    border-radius: clamp(0.75rem, 1.5vw, 1rem);
    padding: clamp(1.5rem, 4vw, 2.5rem);
    box-shadow: 0 1px 3px color-mix(in srgb, var(--color-text) 10%, transparent),
                0 1px 2px color-mix(in srgb, var(--color-text) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-border) 30%, transparent);
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* Page Text Content - MAXIMUM IMAGE CONSTRAINT */
  .page-text {
    line-height: 1.8;
    color: var(--color-text);
    word-wrap: break-word;
    overflow-wrap: break-word;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  /* CRITICAL: Absolute image constraint - multiple methods */
  .page-text img {
    /* Force width constraint */
    max-width: 100% !important;
    width: 100% !important;
    height: auto !important;
    
    /* Display and positioning */
    display: block;
    margin: 1.5rem auto;
    
    /* Prevent overflow */
    object-fit: contain;
    object-position: center;
    
    /* Visual styling */
    border-radius: 0.5rem;
    
    /* Force size recalculation */
    box-sizing: border-box;
  }

  /* Also constrain picture elements */
  .page-text picture {
    max-width: 100% !important;
    width: 100% !important;
    display: block;
    overflow: hidden;
  }

  /* Constrain figure elements */
  .page-text figure {
    max-width: 100% !important;
    width: 100% !important;
    margin: 1.5rem auto;
    overflow: hidden;
  }

  /* Handle iframes, videos, and embeds */
  .page-text iframe,
  .page-text video,
  .page-text embed,
  .page-text object {
    max-width: 100% !important;
    width: 100% !important;
    height: auto !important;
    aspect-ratio: 16 / 9;
    display: block;
  }

  /* Prevent any child element from causing overflow */
  .page-text * {
    max-width: 100%;
    overflow-wrap: break-word;
    word-wrap: break-word;
    box-sizing: border-box;
  }

  /* Tables - make them responsive */
  .page-text table {
    width: 100% !important;
    max-width: 100%;
    overflow-x: auto;
    display: block;
  }

  /* Pre and code blocks */
  .page-text pre,
  .page-text code {
    max-width: 100%;
    overflow-x: auto;
    word-wrap: break-word;
    white-space: pre-wrap;
  }

  /* Typography */
  .page-text h1,
  .page-text h2,
  .page-text h3,
  .page-text h4,
  .page-text h5,
  .page-text h6 {
    color: var(--color-text);
    margin-top: clamp(1.5rem, 3vw, 2.5rem);
    margin-bottom: clamp(0.75rem, 1.5vw, 1rem);
    font-weight: 600;
    line-height: 1.3;
    word-wrap: break-word;
  }

  .page-text h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    border-bottom: 2px solid color-mix(in srgb, var(--color-primary) 80%, transparent);
    padding-bottom: 0.5rem;
  }

  .page-text h3 {
    font-size: clamp(1.25rem, 2.5vw, 1.5rem);
  }

  .page-text p {
    margin-bottom: 1.25rem;
    color: var(--color-text-light);
    word-wrap: break-word;
  }

  .page-text ul,
  .page-text ol {
    margin-bottom: 1.5rem;
    padding-left: clamp(1.5rem, 3vw, 2rem);
  }

  .page-text li {
    margin-bottom: 0.5rem;
    color: var(--color-text-light);
    word-wrap: break-word;
  }

  .page-text a {
    color: var(--color-primary);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
    transition: color 0.2s ease;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  .page-text a:hover {
    color: var(--color-primary-hover);
  }

  /* Sidebar - Strict width control */
  .page-sidebar {
    display: flex;
    flex-direction: column;
    gap: clamp(1.5rem, 3vw, 2rem);
    min-width: 0;
    max-width: 100%;
    overflow: hidden;
    box-sizing: border-box;
  }

  .sidebar-widget {
    background: var(--color-background);
    border-radius: clamp(0.75rem, 1.5vw, 1rem);
    padding: clamp(1.25rem, 3vw, 1.75rem);
    box-shadow: 0 1px 3px color-mix(in srgb, var(--color-text) 10%, transparent),
                0 1px 2px color-mix(in srgb, var(--color-text) 6%, transparent);
    border: 1px solid color-mix(in srgb, var(--color-border) 30%, transparent);
    overflow: hidden;
    box-sizing: border-box;
  }

  .sidebar-widget h3 {
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    margin: 0 0 1.25rem 0;
    color: var(--color-text);
    font-weight: 600;
    border-bottom: 2px solid color-mix(in srgb, var(--color-border) 50%, transparent);
    padding-bottom: 0.75rem;
  }

  .sidebar-widget p {
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  /* Sidebar Links */
  .sidebar-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .sidebar-links li {
    margin-bottom: 0.75rem;
  }

  .sidebar-links a {
    color: black;
    text-decoration: none;
    padding: 0.6rem 0;
    display: block;
    border-radius: 0.5rem;
    transition: all 0.25s ease;
    position: relative;
    padding-left: 1.5rem;

    word-break: break-word;
    overflow-wrap: break-word;
  }

  .sidebar-links a::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: bold;
    transition: transform 0.25s ease;
  }

  .sidebar-links a:hover {
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 5%, transparent);
    padding-left: 1.75rem;
  }

  .sidebar-links a:hover::before {
    transform: translateX(0.25rem);
  }

  /* Newsletter Form */
  .newsletter-form {
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }

  .newsletter-form input {
    padding: 0.875rem 1rem;
    border: 2px solid color-mix(in srgb, var(--color-border) 60%, transparent);
    border-radius: 0.5rem;
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    transition: all 0.25s ease;
    background: var(--color-background);
    color: var(--color-text);
    width: 100%;
    max-width: 100%;
    box-sizing: border-box;
  }

  .newsletter-form input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .newsletter-form input::placeholder {
    color: color-mix(in srgb, var(--color-text-light) 70%, transparent);
  }

  .newsletter-form button {
    padding: 0.875rem 1.5rem;
    font-size: clamp(0.9rem, 1.5vw, 1rem);
    font-weight: 500;
    background: var(--color-primary);
    color: var(--color-background);
    border: none;
    border-radius: 0.5rem;
    cursor: pointer;
    transition: all 0.25s ease;
    width: 100%;
    box-sizing: border-box;
  }

  .newsletter-form button:hover {
    background: var(--color-primary-hover);
    transform: translateY(-1px);
    box-shadow: 0 4px 12px color-mix(in srgb, var(--color-primary) 25%, transparent);
  }

  /* Responsive Breakpoints */
  @media (max-width: 1023px) {
    .page-sidebar {
      order: -1;
    }
  }

  @media (max-width: 768px) {
    .page-content {
      padding: clamp(1.25rem, 3vw, 2rem) clamp(0.875rem, 2.5vw, 1.5rem);
    }
    
    .page-content-wrapper,
    .sidebar-widget {
      padding: clamp(1.25rem, 3vw, 1.75rem);
    }
  }

  @media (max-width: 640px) {
    .page-header {
      border-radius: 0.75rem;
      padding: 1.5rem 1.25rem;
    }
    
    .page-content-wrapper,
    .sidebar-widget {
      border-radius: 0.75rem;
      padding: 1.25rem;
    }
  }

  /* Extra small devices */
  @media (max-width: 480px) {
    .page-content {
      padding: 1rem 0.75rem;
    }
    
    .page-text img {
      margin: 1rem auto;
    }
  }

  /* Print Styles */
  @media print {
    .page-sidebar,
    .newsletter-form {
      display: none;
    }
    
    .page-body {
      grid-template-columns: 1fr;
    }
    
    .page-text img {
      max-width: 100%;
      page-break-inside: avoid;
    }
  }
</style>
